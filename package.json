{
  "name": "cypress-automation-framework",
  "version": "1.0.0",
  "description": "End-to-end Cypress BDD automation framework for Predict360 GRC platform",
  "author": "Muhammad Ammar Ahmed <m.ammarahmed97@gmail.com>",
  "license": "MIT",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:chrome": "cypress run --browser chrome",
    "cy:run:headed": "cypress run --headed",
    "cy:run:compliance": "cypress run --spec 'cypress/e2e/compliance/**/*.cy.js'",
    "cy:run:risk": "cypress run --spec 'cypress/e2e/risk-management/**/*.cy.js'",
    "cy:report": "mochawesome-merge cypress/reports/*.json > cypress/reports/combined.json && marge cypress/reports/combined.json",
    "lint": "eslint cypress/**/*.js"
  },
  "dependencies": {
    "cypress": "^13.6.0",
    "cypress-cucumber-preprocessor": "^4.3.1",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-plugin-cypress": "^2.15.1"
  },
  "cypress-cucumber-preprocessor": {
    "nonGlobalStepDefinitions": true,
    "stepDefinitions": "cypress/support/step_definitions"
  }
}
